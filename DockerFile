FROM python:3.12-slim

WORKDIR /app

# Install system deps for psycopg2-binary (PostgreSQL driver)
RUN apt-get update && apt-get install -y \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-install-recommends -r requirements.txt

COPY . .

EXPOSE 8000

# init_db.py runs at RUNTIME (not build time) so it can reach the DB
CMD ["sh", "-c", "python init_db.py && uvicorn backend.main:app --host 0.0.0.0 --port 8000"]
